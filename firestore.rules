rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Default deny
    match /{document=**} {
      allow read, write: if false;
    }

    // Helpers
    function isSignedIn() {
      return request.auth != null;
    }

    function isAdmin(uid) {
      return exists(/databases/$(database)/documents/admins/$(uid));
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function incoming() { return request.resource.data; }
    function existing() { return resource.data; }

    function isValidBooking(data) {
      return data.customerName is string &&
             data.phone is string &&
             data.address is string &&
             data.status is string &&
             data.createdAt is string;
    }

    match /users/{userId} {
      allow read: if isSignedIn(); // Basic info is public to authenticated users (techs/admins)
      allow create: if isOwner(userId) && (
        incoming().keys().hasAll(['phone', 'role', 'createdAt']) &&
        incoming().role == 'customer' &&
        incoming().phone is string
      );
      allow update: if isOwner(userId) || (isSignedIn() && (
        isAdmin(request.auth.uid) ||
        // Allow technicians/admins to update specific fields like points/badges
        incoming().diff(existing()).affectedKeys().hasAny(['turboPoints', 'lifetimePoints', 'badge'])
      ));
      allow list: if isSignedIn() && isAdmin(request.auth.uid);
    }

    match /admins/{userId} {
      allow read: if isSignedIn();
      allow write: if false; // Only via console or Admin SDK
    }

    match /bookings/{bookingId} {
      allow read, write: if isSignedIn();
    }

    match /rewards/{rewardId} {
      allow read: if true;
      allow write: if isSignedIn() && isAdmin(request.auth.uid);
    }

    match /reward_claims/{claimId} {
      allow read: if isSignedIn() && (resource.data.customerId == request.auth.uid || isAdmin(request.auth.uid));
      allow create: if isSignedIn() && incoming().customerId == request.auth.uid;
      allow update: if isSignedIn() && (
        isAdmin(request.auth.uid) ||
        (resource.data.customerId == request.auth.uid && incoming().diff(existing()).affectedKeys().hasOnly(['status', 'updatedAt']))
      );
    }

    match /rewardClaims/{claimId} {
       // Support for both snake_case and camelCase collections if frontend uses either
      allow read: if isSignedIn() && (resource.data.customerId == request.auth.uid || isAdmin(request.auth.uid));
      allow create: if isSignedIn() && incoming().customerId == request.auth.uid;
      allow update: if isSignedIn() && (
        isAdmin(request.auth.uid) ||
        (resource.data.customerId == request.auth.uid && incoming().diff(existing()).affectedKeys().hasOnly(['status', 'updatedAt']))
      );
    }

    match /otps/{phone} {
      allow read, write: if false; // Only backend (Admin SDK)
    }


    match /test/{docId} {
      allow read, write: if false; // System testing only via Admin SDK
    }
  }
}
